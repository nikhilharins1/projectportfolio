        "# Buscar variables altamente correlacionadas (correlación > 0.85) para identificar posibles redundancias\n",
        "high_corr_pairs = []\n",
        "corr_matrix = Churn_encoded.corr(numeric_only=True)\n",
        "\n",
        "for i in range(len(corr_matrix.columns)):\n",
        "    for j in range(i+1, len(corr_matrix.columns)):\n",
        "        if abs(corr_matrix.iloc[i, j]) > 0.85:\n",
        "            high_corr_pairs.append({\n",
        "                'Variable 1': corr_matrix.columns[i],\n",
        "                'Variable 2': corr_matrix.columns[j],\n",
        "                'Correlation': corr_matrix.iloc[i, j]\n",
        "            })\n",
        "\n",
        "high_corr_df = pd.DataFrame(high_corr_pairs).sort_values('Correlation', key=abs, ascending=False)\n",
        "print(\"Variables with correlation > 0.85:\")\n",
        "print(high_corr_df)\n",
        "\n",
        "# indentificar variables altamente correlacionadas y decidir cuáles eliminar\n",
        "vars_to_remove = set()\n",
        "for idx, row in high_corr_df.iterrows():\n",
        "    # Keep the one with higher correlation to Churn_Yes\n",
        "    corr_var1 = abs(corr_matrix.loc[row['Variable 1'], 'Churn_Yes'])\n",
        "    corr_var2 = abs(corr_matrix.loc[row['Variable 2'], 'Churn_Yes'])\n",
        "    \n",
        "    if corr_var1 < corr_var2:\n",
        "        vars_to_remove.add(row['Variable 1'])\n",
        "    else:\n",
        "        vars_to_remove.add(row['Variable 2'])\n",
        "\n",
        "print(f\"\\nVariables to remove (high correlation): {vars_to_remove}\")\n",
        "\n",
